{
  "id": "quote",
  "name": "Quote",
  "icon": "💬",
  "description": "An inspirational quote",
  "type": "functional",
  "refresh_interval": 1800,
  "loop_delay": 7,
  "category": "entertainment",
  "min_rows": 3,
  "min_cols": 15,
  "settings": [
    {
      "key": "max_length",
      "label": "Max quote length (characters)",
      "type": "number",
      "default": "150",
      "min": "40",
      "max": "300",
      "step": "10",
      "stepper": true
    },
    {
      "key": "refresh_minutes",
      "label": "Fetch a new quote every (minutes)",
      "type": "number",
      "default": "30",
      "min": "1",
      "max": "1440",
      "step": "1",
      "stepper": true
    },
    {
      "key": "loop_delay",
      "label": "Delay Between Pages (seconds)",
      "type": "number",
      "default": "7",
      "min": "2",
      "max": "30",
      "step": "1",
      "stepper": true
    }
  ]
}
